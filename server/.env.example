# Server
PORT=4000
CLIENT_ORIGIN=http://localhost:5173

# Existing local report image roots (used when REPORT_ASSET_BASE_URL is empty)
ARGMAX_IMAGES_ROOT=/absolute/path/to/argmax/images
ASTIR_IMAGES_ROOT=/absolute/path/to/astir/images

# S3 signed URL configuration
AWS_REGION=eu-central-1
AWS_S3_BUCKET=tnhl-ukw
AWS_S3_KEY_PREFIX=cell_type_prediction_l1
AWS_S3_UPLOAD_URL_EXPIRES_SEC=300
AWS_S3_VIEW_URL_EXPIRES_SEC=300

# Optional: if set, report images are served from this base instead of local static folders.
# Example (S3 virtual-hosted): https://your-public-assets-bucket.s3.us-east-1.amazonaws.com
# Example (CloudFront): https://dxxxxxxxxxxxx.cloudfront.net
REPORT_ASSET_BASE_URL=https://tnhl-ukw.s3.eu-central-1.amazonaws.com/cell_type_prediction_l1/outputs

# Optional S3 source for report discovery (catalog/sample listing). Required for fully S3-backed mode.
# If empty, report discovery uses local directories from ARGMAX_IMAGES_ROOT / ASTIR_IMAGES_ROOT.
REPORT_ASSET_S3_BUCKET=tnhl-ukw
REPORT_ASSET_S3_PREFIX=cell_type_prediction_l1/outputs
